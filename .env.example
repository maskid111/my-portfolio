X_BEARER_TOKEN=replace_with_your_x_api_bearer_token
X_USERNAME=deft_gfx
X_USER_ID=

# Optional. X API v2 user lookup may not return a banner image.
# Easiest local option: add your banner image to /public/banner.jpg and use /banner.jpg.
X_PROFILE_BANNER_URL=

# Optional fallback while X API credits are depleted.
# Put your profile image in /public/maskid-pfp.jpg and use /maskid-pfp.jpg.
X_PROFILE_IMAGE_URL=
